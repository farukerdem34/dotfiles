{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dart": {
      "command": [
        "dart",
        "mcp-server"
      ],
      "type": "local",
      "enabled":false
    },
    "nextjs-devtools": {
      "command": [
        "bunx",
        "next-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "playwright": {
      "command": [
        "bunx",
        "@playwright/mcp@0.0.68"
      ],
      "type": "local"
    },
    "serena": {
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "agent"
      ],
      "type": "local"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
