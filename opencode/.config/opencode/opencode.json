{
  "$schema": "https://opencode.ai/config.json",
  "lsp":true,
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=dgirjdccltyeplynalgh",
      "enabled": false
    },
    "dart": {
      "command": [
        "dart",
        "mcp-server"
      ],
      "type": "local",
      "enabled": false
    },
    "nextjs-devtools": {
      "command": [
        "bunx",
        "next-devtools-mcp@latest"
      ],
      "type": "local",
      "enabled": false
    },
    "playwright": {
      "command": [
        "bunx",
        "@playwright/mcp@0.0.68"
      ],
      "type": "local",
      "enabled": false
    },
    "serena": {
      "command": [
          "serena",
          "start-mcp-server",
          "--context",
          "ide"
      ],
      "type": "local"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "browser mcp": {
      "type": "local",
      "enabled": false,
      "command": [
        "bunx",
        "@browsermcp/mcp@latest"
      ]
    }
  }
}
